# CriticalAsset API credentials. Copy to `.env` and fill in real values.
# These stay SERVER-SIDE only (no NEXT_PUBLIC_ prefix) — never sent to the browser.

CA_API_URL=https://<your-subdomain>.stg.criticalasset.com/api
CA_CLIENT_ID=ca_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CA_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: a pre-minted access token. NOT required — the backend mints and
# refreshes its own token from the client id/secret above on demand.
# CA_ACCESS_TOKEN=

# Anthropic API key — powers the AI field-intake / workflow layer (Challenge 02).
# Server-side only. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
